{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "ScheduleWakeup",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/packages/engine/hooks/dev-mode-tool-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/packages/engine/hooks/dev-mode-tool-guard.sh"
          }
        ]
      }
    ]
  }
}
