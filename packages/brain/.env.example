# Brain 环境变量示例
# 复制此文件为 .env 并填入真实值
# 注意：.env 已在 .gitignore 中，不会提交到 git

# 区域标识
ENV_REGION=us

# 西安 Codex Bridge URL
XIAN_CODEX_BRIDGE_URL=http://localhost:13458

# N8N API
N8N_API_URL=http://100.86.118.99:5679

# API Keys（填入真实值）
MINIMAX_API_KEY=your-minimax-api-key

# 并发保护层（必须与 docker-compose.yml environment 块保持一致）
# CECELIA_BUDGET_SLOTS：Layer 2 预算上限，限制最大并发 agent 数
# 这两个值必须同时在 .env（裸进程）和 docker-compose.yml（容器）中设置
CECELIA_BUDGET_SLOTS=7
CECELIA_MAX_SEATS=10
