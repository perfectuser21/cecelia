{
  "name": "cecelia-brain",
  "type": "module",
  "description": "Cecelia Node.js Brain - decision engine, tick loop, and action system",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "bash -c 'NODE_OPTIONS=\"--max-old-space-size=3072\" npx vitest run 2>&1 | tee /tmp/brain-vitest-out.txt; EXIT=${PIPESTATUS[0]}; if [ $EXIT -ne 0 ] && grep -qE \"Tests.*[0-9]+ passed\" /tmp/brain-vitest-out.txt && ! grep -qE \"Tests.*[0-9]+ failed\" /tmp/brain-vitest-out.txt; then echo \"[test] OOM worker exit, all tests passed\"; exit 0; fi; exit $EXIT'",
    "test:watch": "vitest",
    "test:coverage": "NODE_OPTIONS='--max-old-space-size=3072' vitest run --coverage",
    "test:coverage:watch": "vitest --coverage",
    "backfill:l1": "node src/scripts/backfill-l1.js",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-otlp-http": "^0.26.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "bullmq": "^5.28.2",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "ioredis": "^5.4.1",
    "js-yaml": "^4.1.1",
    "natural": "^7.0.7",
    "openai": "^4.77.3",
    "pg": "^8.12.0",
    "uuid": "^9.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^9.39.2",
    "globals": "^15.15.0",
    "supertest": "^7.2.2",
    "vitest": "^1.6.1"
  },
  "version": "1.227.1"
}
