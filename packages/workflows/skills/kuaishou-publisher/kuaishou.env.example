# 快手开放平台凭据模板
# 保存为 ~/.credentials/kuaishou.env（chmod 600）
#
# 获取步骤：
#   1. 登录 https://open.kuaishou.com/platform 创建应用
#   2. 获取 AppKey 和 AppSecret
#   3. 完成 OAuth 授权（参见 SKILL.md）

# === 应用凭据（必需）===
KUAISHOU_APP_KEY=<your_app_key>
KUAISHOU_APP_SECRET=<your_app_secret>

# === OAuth Token（运行 exchange-code 后自动填写）===
KUAISHOU_ACCESS_TOKEN=
KUAISHOU_REFRESH_TOKEN=
KUAISHOU_TOKEN_EXPIRES_AT=
KUAISHOU_OPEN_ID=
