      "parameters": {
        "command": "echo \"{{ $json.sqlBase64 }}\" | base64 -d > /tmp/ds_insert_$(date +%s).sql && docker exec -i cecelia-postgres psql -U cecelia -d timescaledb < /tmp/ds_insert_*.sql && rm -f /tmp/ds_insert_*.sql && echo '{\"db_write\":\"ok\"}'",
        "host": "134.199.234.147",
