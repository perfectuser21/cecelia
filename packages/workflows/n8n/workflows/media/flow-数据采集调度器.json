      "id": "alert",
      "name": "\\u53d1\\u9001\\u544a\\u8b66",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2550,
        200
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const r = $json;\nconst runDate = new Date().toISOString().split('T')[0];\n\nlet sql = `CREATE SCHEMA IF NOT EXISTS zenithjoy;\nCREATE TABLE IF NOT EXISTS zenithjoy.data_sources (\n  id SERIAL PRIMARY KEY,\n  run_date DATE NOT NULL,\n  platform VARCHAR(50) NOT NULL,\n  success BOOLEAN NOT NULL,\n  record_count INTEGER DEFAULT 0,\n  error_message TEXT,\n  duration_seconds REAL DEFAULT 0,\n  scraped_at TIMESTAMPTZ DEFAULT NOW(),\n  UNIQUE(run_date, platform)\n);\n`;\n\nif (r.results && r.results.length > 0) {\n  const values = r.results.map(p => {\n    const safeP = p.platform.replace(/'/g, \"''\");\n    const safeErr = p.error ? `'${String(p.error).replace(/'/g, \"''\")}'` : 'NULL';\n    const dur = r.duration_seconds || 0;\n    return `('${runDate}', '${safeP}', ${p.success ? 'true' : 'false'}, ${p.count || 0}, ${safeErr}, ${dur}, NOW())`;\n  }).join(',\\n');\n  sql += `INSERT INTO zenithjoy.data_sources (run_date, platform, success, record_count, error_message, duration_seconds, scraped_at) VALUES\\n${values}\\nON CONFLICT (run_date, platform) DO UPDATE SET\\n  success=EXCLUDED.success,\\n  record_count=EXCLUDED.record_count,\\n  error_message=EXCLUDED.error_message,\\n  duration_seconds=EXCLUDED.duration_seconds,\\n  scraped_at=NOW();\\n`;\n}\n\nconst sqlBase64 = Buffer.from(sql).toString('base64');\nreturn { ...r, sqlBase64 };"
      },
      "id": "gendb",
      "name": "\\u751f\\u6210DB\\u8bed\\u53e5",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
