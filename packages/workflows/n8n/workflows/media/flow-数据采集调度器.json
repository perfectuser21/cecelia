        "method": "POST",
        "url": "https://open.feishu.cn/open-apis/bot/v2/hook/5bde68e0-9879-4a45-88ed-461a88229136",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"msg_type\": \"text\", \"content\": { \"text\": \"\\ud83d\\udea8 \\u91c7\\u96c6\\u544a\\u8b66\\n\\n\" + $('\\u6c47\\u603b').item.json.failed.length + \" \\u4e2a\\u5e73\\u53f0\\u91c7\\u96c6\\u5931\\u8d25: \" + $('\\u6c47\\u603b').item.json.failed.join(', ') + \"\\n\\n\\u8bf7\\u68c0\\u67e5\\u91c7\\u96c6\\u7cfb\\u7edf\\uff01\" } } }}"
