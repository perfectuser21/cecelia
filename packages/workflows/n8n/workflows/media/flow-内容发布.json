    {
      "id": "n5",
      "name": "\u89e3\u6790\u5e76\u6784\u5efa\u901a\u77e5",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1360,
        300
      ],
      "parameters": {
        "jsCode": "const stdout = $input.first().json.stdout || '';\nconst prev = $('\u51c6\u5907').first().json;\n\nconst platformNames = { douyin: '\u6296\u97f3', xiaohongshu: '\u5c0f\u7ea2\u4e66' };\nconst platformDisplay = platformNames[prev.platform] || prev.platform;\n\nlet success = false;\nlet error = '';\n\ntry {\n  const m = stdout.match(/\\{[\\s\\S]*?\\}/);\n  if (m) {\n    const r = JSON.parse(m[0]);\n    success = r.success === true;\n    error = r.error || '';\n  }\n} catch (e) {\n  error = '\u89e3\u6790\u5931\u8d25';\n}\n\nconst emoji = success ? '\u2705' : '\u274c';\nconst status = success ? '\u53d1\u5e03\u6210\u529f' : '\u53d1\u5e03\u5931\u8d25';\nlet text = emoji + ' ' + status + '\\n';\ntext += '\u5e73\u53f0: ' + platformDisplay + '\\n';\ntext += '\u6807\u9898: ' + prev.title;\nif (error) text += '\\n\u9519\u8bef: ' + error;\n\nreturn [{\n  json: {\n    taskId: prev.taskId,\n    success,\n    feishuBody: { msg_type: 'text', content: { text } }\n  }\n}];"
      }
    },
    {
      "id": "n11",
      "name": "\u89e3\u6790-\u5c0f\u7ea2\u4e66",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1360,
        520
      ],
      "parameters": {
        "jsCode": "const stdout = $input.first().json.stdout || '';\nconst prev = $('\u51c6\u5907').first().json;\n\nlet success = false;\nlet error = '';\n\nif (stdout.includes('success') || stdout.includes('\u6210\u529f')) {\n  success = true;\n} else if (stdout.includes('error') || stdout.includes('\u5931\u8d25') || stdout.includes('Error')) {\n  success = false;\n  error = stdout.split('\\n').find(l => l.toLowerCase().includes('error')) || '\u672a\u77e5\u9519\u8bef';\n} else {\n  success = stdout.trim().length > 0;\n}\n\ntry {\n  const m = stdout.match(/\\{[\\s\\S]*?\\}/);\n  if (m) {\n    const r = JSON.parse(m[0]);\n    if (typeof r.success === 'boolean') success = r.success;\n    if (r.error) error = r.error;\n  }\n} catch (e) {}\n\nconst emoji = success ? '\u2705' : '\u274c';\nconst status = success ? '\u53d1\u5e03\u6210\u529f' : '\u53d1\u5e03\u5931\u8d25';\nlet text = emoji + ' ' + status + '\\n';\ntext += '\u5e73\u53f0: \u5c0f\u7ea2\u4e66\\n';\ntext += '\u6807\u9898: ' + prev.title;\nif (error) text += '\\n\u9519\u8bef: ' + error;\n\nreturn [{\n  json: {\n    taskId: prev.taskId,\n    success,\n    feishuBody: { msg_type: 'text', content: { text } }\n  }\n}];"
      }
    },
