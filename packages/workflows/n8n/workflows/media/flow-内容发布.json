      "id": "n2",
      "name": "\u51c6\u5907",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        420,
        300
      ],
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst taskId = body.taskId || '';\nconst title = body.title || '(\u65e0\u6807\u9898)';\nconst content = body.content || '';\nconst platforms = body.targetPlatforms || [];\n\nconst supported = ['douyin', 'xiaohongshu'];\nconst valid = platforms.filter(p => supported.includes(p));\n\nif (valid.length === 0) {\n  return [{ json: { skip: true, taskId, title, content, reason: '\u6ca1\u6709\u652f\u6301\u7684\u5e73\u53f0' } }];\n}\n\nreturn [{ json: { skip: false, taskId, title, content, platform: valid[0] } }];"
      }
    },
