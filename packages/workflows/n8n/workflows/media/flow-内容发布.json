      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        420,
        400
      ],
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst taskId = body.taskId || '';\nconst title = body.title || '(无标题)';\nconst content = body.content || '';\nconst contentDir = body.contentDir || '';\n\n// 支持 platform 单值（新）和 targetPlatforms 数组（旧，取第一个）\nconst platform = body.platform || (Array.isArray(body.targetPlatforms) && body.targetPlatforms[0]) || '';\nconst contentType = body.contentType || 'image';\n\nconst supported = ['douyin', 'kuaishou', 'xiaohongshu'];\nif (!platform || !supported.includes(platform)) {\n  return [{ json: { error: true, errorCode: 400, taskId, title, reason: '不支持的平台: ' + (platform || '(未指定)') } }];\n}\n\nreturn [{ json: { error: false, taskId, title, content, contentDir, platform, contentType } }];"
      }
    },
