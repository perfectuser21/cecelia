# Cecelia Brain Staging 配置模板
# 复制此文件为 .env.staging 并填写实际值
# .env.staging 不会被 git 追踪（已加入 .gitignore）

# PostgreSQL（staging DB 与 production 同实例，不同 database）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cecelia_staging
DB_USER=cecelia
DB_PASSWORD=YOUR_PASSWORD_HERE

# Brain 配置（staging：tick 禁用）
CECELIA_TICK_ENABLED=false
CECELIA_TICK_INTERVAL_MS=5000
DISPATCH_TIMEOUT_MINUTES=60

# Region
ENV_REGION=us

# Cecelia Run
CLAUDE_HOME=/home/xx/.claude
SKILLS_PATH=/home/xx/.claude/skills
CLAUDE_MODEL=claude-sonnet-4-5

# Feishu（staging 通常不需要，留空即可）
FEISHU_OWNER_OPEN_IDS=
FEISHU_BOT_WEBHOOK=
